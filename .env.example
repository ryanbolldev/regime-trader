# Alpaca broker credentials
# Get these from https://app.alpaca.markets/paper-trading (paper) or live account
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=                  # e.g. https://paper-api.alpaca.markets

# Email alert credentials (SMTP)
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=                   # comma-separated recipients

# Webhook alert (e.g. Slack incoming webhook URL)
ALERT_WEBHOOK_URL=
